/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */
    // 极早期初始化

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */
    // 外设初始化

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */
    // 系统初始化

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_DMA_Init();
  MX_USART1_UART_Init();
  MX_I2C2_Init();
  MX_TIM2_Init();
  MX_TIM4_Init();
  MX_SPI1_Init();
  /* USER CODE BEGIN 2 */
    // 应用初始化
    HAL_TIM_Base_Start_IT(&htim2);
    HAL_TIM_PWM_Start(&htim4, TIM_CHANNEL_4);

    // UART接收中断
    HAL_UART_Receive_IT(&huart1, (uint8_t*)&recv_buf, 1);

    userShellInit();

    // u8g2Init(&u8g2);


    u8g2_Setup_ssd1315_i2c_128x64_noname_f(
        &u8g2_a,
        U8G2_R0,
        u8x8_byte_hw_i2c_stm32,
        u8x8_stm32_gpio_and_delay
    );
    u8g2_InitDisplay(&u8g2_a);
    u8g2_SetPowerSave(&u8g2_a, 0);


    u8g2_Setup_ssd1315_128x64_noname_f(
        &u8g2_b,
        U8G2_R0,
        u8x8_byte_hw_spi_stm32,
        u8x8_stm32_gpio_and_delay
    );
    u8g2_InitDisplay(&u8g2_b);
    u8g2_SetPowerSave(&u8g2_b, 0);


  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
    while (1)
    {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
        // 用户代码 ===================================================

        // if (trigger >= 500)
        // {
        //     uint8_t len = sprintf((char*)tx_buffer, "咕咕嘎嘎\n");
        //     HAL_UART_Transmit_DMA(&huart1, tx_buffer, len);
        //
        //     trigger = 0;
        // }


        u8g2_FirstPage(&u8g2_a);
        do
        {
            draw(&u8g2_a);
        }
        while (u8g2_NextPage(&u8g2_a));

        u8g2_FirstPage(&u8g2_b);
        do
        {
            draw(&u8g2_b);
        }
        while (u8g2_NextPage(&u8g2_b));

        // draw(&u8g2);
        // u8g2_SendBuffer(&u8g2);

        // UART_GPIO_Indicator(&huart1, LED2_GPIO_Port, LED2_Pin, 0, 0);

        // 用户代码 ===================================================
    }
  /* USER CODE END 3 */
}

